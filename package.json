{
  "name": "git-undo",
  "version": "1.0.0",
  "description": "Undo git mistakes in plain English",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "git-undo": "./bin/git-undo.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outfile bin/git-undo.js --target node",
    "dev": "bun --watch src/index.ts"
  },
  "keywords": ["git", "undo", "cli", "developer-tools"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  }
}
